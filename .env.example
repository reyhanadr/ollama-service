# =============================================================================
# Ollama Shared Service — Environment Configuration
# =============================================================================
# Copy file ini ke .env dan sesuaikan nilainya:
#   cp .env.example .env
# =============================================================================

# --- Ollama Server ---
# Host binding di dalam container (0.0.0.0 = listen di semua interface)
OLLAMA_HOST=0.0.0.0

# Port Ollama di host (default: 11434)
OLLAMA_PORT=11434

# Jumlah paralel request yang bisa diproses Ollama (default: 1)
# Naikkan jika banyak container lain mengakses secara bersamaan
OLLAMA_NUM_PARALLEL=4

# Maksimal jumlah model yang dimuat ke memory secara bersamaan
OLLAMA_MAX_LOADED_MODELS=2

# --- Docker Network ---
# Nama shared network yang digunakan semua container
NETWORK_NAME=ollama-net

# --- Docker Volume ---
# Nama volume untuk persistensi model
VOLUME_NAME=ollama-data

# --- Hugging Face ---
# Token Hugging Face untuk pull model dari hf.co (wajib jika pakai model HF)
# Dapatkan di: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# --- GPU (Opsional) ---
# Uncomment baris deploy.resources di docker-compose.yml jika punya NVIDIA GPU
# Pastikan nvidia-container-toolkit sudah terinstall:
#   nvidia-smi
