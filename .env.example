# =============================================================================
# Ollama Shared Service — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust the values:
#   cp .env.example .env
# =============================================================================

# --- Ollama Server ---
# Host binding di dalam container (0.0.0.0 = listen di semua interface)
OLLAMA_HOST=0.0.0.0

# Port Ollama di host (default: 11434)
OLLAMA_PORT=11434

# Jumlah paralel request yang bisa diproses Ollama (default: 1)
# Increase if many other containers access it concurrently
OLLAMA_NUM_PARALLEL=4

# Maximum number of models loaded into memory simultaneously
OLLAMA_MAX_LOADED_MODELS=2

# --- Docker Network ---
# Nama shared network yang digunakan semua container
NETWORK_NAME=ollama-net

# --- Docker Volume ---
# Nama volume untuk persistensi model
VOLUME_NAME=ollama-data

# --- Hugging Face ---
# Hugging Face token for pulling models from hf.co (required if using HF models)
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# --- GPU (Opsional) ---
# Uncomment the deploy.resources block in docker-compose.yml if you have an NVIDIA GPU
# Pastikan nvidia-container-toolkit sudah terinstall:
#   nvidia-smi
